}

class Warehouse {
  - warehouseId: int
  - location: String
  - capacity: int
  - occupancyRate: float
  + addItem(): void
  + removeItem(): void
  + checkCapacity(): boolean
}

class PickList {
  - pickListId: int
  - optimizedRoute: String
  - status: String
