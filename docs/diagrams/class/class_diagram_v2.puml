}

class Supplier {
  - supplierId: int
  - companyName: String
  - contactInfo: String
  + supplyItems(): void
  + confirmOrder(): boolean
  + getPerformance(): Report
  + notifyObserver(): void
  + applyTieredLogic(price: float, speed: float): void
  + sendOP(): void
