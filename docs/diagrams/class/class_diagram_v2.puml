}

interface StockObserver {
  + update(event: String): void
  + getObserverId(): int
}

enum InboundStatus {
  EXPECTED
  AT_DOCK
  BEING_INSPECTED
  STORED
}

enum OrderStatus {
  PROCESSING
  PICKING
  PACKING
  SHIPPED
  DELIVERED
}

