  + checkAvailability(): boolean
}

class EmergencyEvent {
  - eventId: int
  - reason: String
  - timestamp: Date
  - resolved: boolean
  + activate(): void
  + deactivate(): void
}

class BackOrder {
  - backOrderId: int
  - reason: String
  + createBackOrder(): void
  + resolveBackOrder(): void
}

class Shipment {
  - shipmentId: int
  - status: String
  - carrierId: int
