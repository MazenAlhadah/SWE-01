@startuml UC-05_Manage_Procurement_Purchase_Orders
title UC-05 — Manage Procurement & Purchase Orders

box "Actors"
actor ":WarehouseManager" as Manager
end box

box "System"
participant ":ProcurementUI" as UI
participant ":ProcurementController" as PC
participant ":SupplierSelector" as SS
participant ":POGenerator" as POG
participant ":SupplierPortal" as SP
database ":Database" as DB
end box

PC -> DB : monitorStockLevels()
activate PC
activate DB
DB --> PC : stockData[]
deactivate DB

PC -> PC : checkSafetyStockThreshold(stockData)
activate PC
PC --> PC : thresholdBreached
deactivate PC

opt stock <= safetyThreshold
    PC -> DB : fetchAffectedSKUs()
    activate DB
    DB --> PC : affectedSKUs[]
    deactivate DB
    PC --> UI : pushReorderNotification(affectedSKUs)
    activate UI
    UI --> Manager : showReorderAlert(affectedSKUs)
    deactivate UI
end

deactivate PC

Manager -> UI : reviewReorderRecommendation()
activate UI
UI -> PC : requestReorderDetails(affectedSKUs)
activate PC
PC -> DB : fetchSKUDetails(affectedSKUs)
activate DB
DB --> PC : skuDetails[]
deactivate DB
PC --> UI : reorderDetails(skuDetails)
deactivate PC
UI --> Manager : displayReorderDetails(skuDetails)

== opt: Extension Point — Evaluation ==

opt manager selects 'evaluate before order'
    note right of Manager : Triggers UC-04\n(View Supplier Performance & Analytics)
    Manager -> UI : selectEvaluateBeforeOrder()
end

Manager -> UI : proceedWithOrder(skuList)

UI -> SS : runTieredSupplierSelection(skuList)
activate SS
SS -> DB : fetchSupplierOptions(skuList)
activate DB
DB --> SS : suppliers{price, deliverySpeed}
deactivate DB
SS -> SS : applySelectionRule(price, deliverySpeed)
activate SS
SS --> SS : selectedSupplier
deactivate SS
SS --> UI : selectedSupplier{supplierId, skuList}
deactivate SS

UI -> POG : generatePurchaseOrder(selectedSupplier, skuList)
activate POG
POG -> DB : fetchUnitPrices(skuList, supplierId)
activate DB
DB --> POG : prices[]
deactivate DB
POG -> POG : buildPO(SKUs, quantities, unitPrices, totalCost)
activate POG
POG --> POG : poData
deactivate POG
POG -> POG : applyDigitalSignature()
activate POG
POG --> POG : signedPO
deactivate POG
POG -> DB : persistPO(poData)
activate DB
DB --> POG : poId
deactivate DB
POG --> UI : purchaseOrderReady(poId, poPreview)
deactivate POG

UI --> Manager : displayPOForApproval(poPreview)

Manager -> UI : approvePO(poId)
UI -> PC : sendPOToSupplier(poId)
activate PC
PC -> SP : deliverPO(poData)
activate SP
SP --> PC : poReceived()
deactivate SP
PC -> DB : logPOSent(poId, timestamp)
activate DB
DB --> PC : logged
deactivate DB
PC --> UI : poSent()
deactivate PC
UI --> Manager : confirmPOSentToSupplier()

note over PC : Includes UC-16\n(Receive & Confirm Purchase Order)

deactivate UI

@enduml
