@startuml UC-20_Undergo_Performance_Audit
title UC-20 — Undergo Performance Audit

box "Actors"
actor ":Supplier" as Supplier
end box

box "System"
participant ":SupplierPortal" as SP
participant ":AuditController" as AC
participant ":TierRankingService" as TRS
database ":Database" as DB
end box

Supplier -> SP : openPerformanceReport()
activate SP

SP -> AC : requestPerformanceAudit(supplierId)
activate AC

AC -> DB : fetchDeliveryHistory(supplierId)
activate DB
DB --> AC : deliveryHistory{ordersPlaced, itemsOrdered, itemsCorrectlyReceived}[]
deactivate DB

AC -> AC : calculateAccuracyScore(deliveryHistory)
activate AC
AC --> AC : accuracyScore
deactivate AC
note right of AC
  Accuracy Score =
  itemsCorrectlyReceived / itemsOrdered
  (updated after every inbound reconciliation — FR14)
end note

AC -> DB : persistUpdatedAccuracyScore(supplierId, accuracyScore)
activate DB
DB --> AC : saved
deactivate DB

AC -> TRS : updateSupplierTierRanking(supplierId, accuracyScore)
activate TRS
TRS -> DB : fetchAllSupplierScores()
activate DB
DB --> TRS : allScores[]
deactivate DB
TRS -> TRS : recomputeTierRankings(allScores)
activate TRS
TRS --> TRS : rankings[]
deactivate TRS
note right of TRS
  Tier ranking feeds into
  UC-05 Tiered Supplier
  Selection Logic (FR15)
end note
TRS -> DB : updateTierRankings(rankings)
activate DB
DB --> TRS : updated
deactivate DB
TRS --> AC : newTierRank{supplierId, tier}
deactivate TRS

AC --> SP : auditReport{accuracyScore, tierRank, deliveryHistory}
deactivate AC

SP --> Supplier : displayPerformanceReportAndTierRanking(auditReport)
deactivate SP

@enduml
