@startuml UC-16_Receive_Confirm_Purchase_Order
title UC-16 — Receive & Confirm Purchase Order\n(included by UC-05)

note over SP : Triggered when PO is generated and sent by UC-05

box "Actors"
actor ":Supplier" as Supplier
end box

box "System"
participant ":SupplierPortal" as SP
participant ":POController" as POC
participant ":ProcurementController" as PC
database ":Database" as DB
end box

SP --> Supplier : notifyNewPurchaseOrderReceived()
Supplier -> SP : openPurchaseOrder(poId)
activate SP

SP -> POC : fetchPODetails(poId)
activate POC
POC -> DB : getPO(poId)
activate DB
DB --> POC : poData{SKUs, quantities, unitPrices, totalCost, signature}
deactivate DB
POC --> SP : displayPO(poData)
deactivate POC
SP --> Supplier : showPODetails(poData)

alt supplier confirms
    Supplier -> SP : confirmPO(poId)
    SP -> POC : submitConfirmation(poId, supplierId)
    activate POC
    POC -> DB : updatePOStatus(poId, "Confirmed")
    activate DB
    DB --> POC : updated
    deactivate DB
    POC -> PC : notifyPOConfirmed(poId)
    activate PC
    PC -> DB : logConfirmation(poId, timestamp)
    activate DB
    DB --> PC : logged
    deactivate DB
    PC --> POC : acknowledged()
    deactivate PC
    POC --> SP : confirmationAcknowledged()
    deactivate POC
    SP --> Supplier : poConfirmed_ProcurementContinues()

else supplier requests modification
    Supplier -> SP : requestModification(poId, modificationDetails)
    SP -> POC : submitModificationRequest(poId, modificationDetails)
    activate POC
    POC -> DB : logModificationRequest(poId, modificationDetails)
    activate DB
    DB --> POC : logged
    deactivate DB
    POC -> PC : notifyManagerModificationRequested(poId)
    activate PC
    PC --> POC : received()
    deactivate PC
    POC --> SP : modificationRequestReceived()
    deactivate POC
    SP --> Supplier : modificationSent_AwaitingManagerReview()
end

deactivate SP

@enduml
